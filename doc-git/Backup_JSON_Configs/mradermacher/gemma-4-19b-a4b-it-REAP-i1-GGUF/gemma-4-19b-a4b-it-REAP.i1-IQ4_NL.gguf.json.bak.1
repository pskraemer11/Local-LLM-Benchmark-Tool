                                                       "jinjaPromptTemplate":  {
                                                                                   "template":  "{{- bos_token -}}\n{%- if (enable_thinking is defined and enable_thinking) or tools or messages[0][\u0027role\u0027] in [\u0027system\u0027, \u0027developer\u0027] -%}\n    {{- \u0027\u003c|turn\u003esystem\\n\u0027 -}}\n    {%- if enable_thinking is defined and enable_thinking -%}\n        {{- \u0027\u003c|think|\u003e\\n\u0027 -}}\n    {%- endif -%}\n    {%- if messages[0][\u0027role\u0027] in [\u0027system\u0027, \u0027developer\u0027] -%}\n        {%- set loop_messages = messages[1:] -%}\n    {%- else -%}\n        {%- set loop_messages = messages -%}\n    {%- endif -%}\n    {%- if tools -%}\n        {%- for tool in tools -%}\n            {{- \u0027\u003c|tool\u003e\u0027 -}}\n            {{- \u0027declaration:\u0027 + tool[\u0027function\u0027][\u0027name\u0027] -}}\n            {{- \u0027{description:\u003c|\"|\u003e\u0027 + tool[\u0027function\u0027][\u0027description\u0027] + \u0027\u003c|\"|\u003e\u0027 -}}\n            {%- if tool[\u0027function\u0027][\u0027parameters\u0027] -%}\n                {{- \u0027,parameters:{type:\u003c|\"|\u003eOBJECT\u003c|\"|\u003e}\u0027 -}}\n            {%- endif -%}\n            {{- \u0027}\u0027 -}}\n            {{- \u0027\u003ctool|\u003e\u0027 -}}\n        {%- endfor -%}\n    {%- endif -%}\n    {{- \u0027\u003cturn|\u003e\\n\u0027 -}}\n{%- else -%}\n    {%- set loop_messages = messages -%}\n{%- endif -%}\n\n{%- for message in loop_messages -%}\n    {%- if message[\u0027role\u0027] == \u0027tool\u0027 -%}\n        {%- set prev_was_assistant = False -%}\n        {%- if loop.index0 \u003e 0 -%}\n            {%- set prev = loop_messages[loop.index0 - 1] -%}\n            {%- set prev_was_assistant = prev[\u0027role\u0027] == \u0027assistant\u0027 -%}\n        {%- endif -%}\n        {%- if prev_was_assistant -%}\n            {%- set tc_id = \u0027\u0027 -%}\n            {%- if message.get(\u0027tool_call_id\u0027) -%}\n                {%- for tc in loop_messages[loop.index0 - 1].get(\u0027tool_calls\u0027, []) -%}\n                    {%- if tc.get(\u0027id\u0027) == message[\u0027tool_call_id\u0027] -%}\n                        {%- set tc_id = tc[\u0027function\u0027][\u0027name\u0027] -%}\n                    {%- endif -%}\n                {%- endfor -%}\n            {%- else -%}\n                {%- set tc_id = message.get(\u0027name\u0027, \u0027unknown\u0027) -%}\n            {%- endif -%}\n            {{- \u0027\u003c|tool_response\u003e\u0027 -}}\n            {{- \u0027response:\u0027 + tc_id + \u0027{value:\u003c|\"|\u003e\u0027 + message[\u0027content\u0027] + \u0027\u003c|\"|\u003e}\u0027 -}}\n            {{- \u0027\u003ctool_response|\u003e\u0027 -}}\n        {%- endif -%}\n    {%- elif message[\u0027role\u0027] == \u0027user\u0027 -%}\n        {%- set prev_was_model = False -%}\n        {%- if loop.index0 \u003e 0 -%}\n            {%- set prev = loop_messages[loop.index0 - 1] -%}\n            {%- set prev_was_model = prev[\u0027role\u0027] == \u0027model\u0027 or prev[\u0027role\u0027] == \u0027assistant\u0027 -%}\n        {%- endif -%}\n        {%- if not prev_was_model -%}\n            {{- \u0027\u003c|turn\u003euser\\n\u0027 -}}\n        {%- endif -%}\n        {%- if message[\u0027content\u0027] is string -%}\n            {{- message[\u0027content\u0027] | trim -}}\n        {%- else -%}\n            {%- for item in message[\u0027content\u0027] -%}\n                {%- if item[\u0027type\u0027] == \u0027text\u0027 -%}\n                    {{- item[\u0027text\u0027] | trim -}}\n                {%- endif -%}\n            {%- endfor -%}\n        {%- endif -%}\n        {{- \u0027\u003cturn|\u003e\\n\u0027 -}}\n    {%- elif message[\u0027role\u0027] == \u0027assistant\u0027 or message[\u0027role\u0027] == \u0027model\u0027 -%}\n        {%- if loop.first or loop_messages[loop.index0 - 1][\u0027role\u0027] != \u0027assistant\u0027 -%}\n            {{- \u0027\u003c|turn\u003emodel\\n\u0027 -}}\n        {%- endif -%}\n        {%- if message[\u0027tool_calls\u0027] -%}\n            {%- for tc in message[\u0027tool_calls\u0027] -%}\n                {{- \u0027\u003c|tool_call\u003ecall:\u0027 + tc[\u0027function\u0027][\u0027name\u0027] + \u0027{\u0027 + tc[\u0027function\u0027][\u0027arguments\u0027] + \u0027}\u003ctool_call|\u003e\u0027 -}}\n            {%- endfor -%}\n        {%- endif -%}\n        {%- if message[\u0027content\u0027] is string and message[\u0027content\u0027] | trim | length \u003e 0 -%}\n            {{- message[\u0027content\u0027] | trim -}}\n        {%- endif -%}\n        {%- if not message.get(\u0027tool_calls\u0027) -%}\n            {{- \u0027\u003cturn|\u003e\\n\u0027 -}}\n        {%- endif -%}\n    {%- endif -%}\n{%- endfor -%}\n\n{%- if add_generation_prompt -%}\n    {{- \u0027\u003c|turn\u003emodel\\n\u0027 -}}\n{%- endif -%}\n"
                                                                               },
