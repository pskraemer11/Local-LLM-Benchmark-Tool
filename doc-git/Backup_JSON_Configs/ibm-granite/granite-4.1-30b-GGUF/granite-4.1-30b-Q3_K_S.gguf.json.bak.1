                                                       "jinjaPromptTemplate":  {
                                                                                   "template":  "{%- if available_tools is defined and available_tools %}\n    {%- set tools = available_tools %}\n{%- endif %}\n{%- set ns = namespace(tools_msg=\u0027\u0027, sys=\u0027\u0027) %}\n{%- if tools %}\n    {%- set ns.tools_msg = \u0027You are a helpful assistant with access to the following tools. Return each tool call as JSON with \"name\" and \"arguments\" inside \u003ctool_call\u003e\u003c/tool_call\u003e:\\n\u003ctools\u003e\u0027 %}\n    {%- for t in tools %}\n        {%- set ns.tools_msg = ns.tools_msg + \u0027\\n\u0027 + (t | tojson) %}\n    {%- endfor %}\n    {%- set ns.tools_msg = ns.tools_msg + \u0027\\n\u003c/tools\u003e\u0027 %}\n{%- endif %}\n{%- if messages[0].role == \u0027system\u0027 %}\n    {%- if messages[0].content is string %}\n        {%- set ns.sys = messages[0].content %}\n    {%- elif messages[0].content is iterable %}\n        {%- for entry in messages[0].content if entry.type == \u0027text\u0027 %}\n            {%- if ns.sys %}\n                {%- set ns.sys = ns.sys + \u0027\\n\u0027 %}\n            {%- endif %}\n            {%- set ns.sys = ns.sys + entry.text %}\n        {%- endfor %}\n    {%- endif %}\n    {%- if ns.tools_msg %}\n        {%- set ns.sys = ns.sys + \u0027\\n\\n\u0027 + ns.tools_msg %}\n    {%- endif %}\n{%- elif ns.tools_msg %}\n    {%- set ns.sys = ns.tools_msg %}\n{%- endif %}\n{%- if ns.sys %}\n{{- \u0027\u003c|start_of_role|\u003esystem\u003c|end_of_role|\u003e\u0027 + ns.sys + \u0027\u003c|end_of_text|\u003e\\n\u0027 }}\n{%- endif %}\n{%- for msg in messages %}\n    {%- set c = \u0027\u0027 %}\n    {%- if msg.content is string %}\n        {%- set c = msg.content %}\n    {%- elif msg.content is iterable %}\n        {%- for entry in msg.content if entry.type == \u0027text\u0027 %}\n            {%- if c %}\n                {%- set c = c + \u0027\\n\u0027 %}\n            {%- endif %}\n            {%- set c = c + entry.text %}\n        {%- endfor %}\n    {%- endif %}\n    {%- if msg.role in (\u0027user\u0027, \u0027system\u0027) and not loop.first %}\n{{- \u0027\u003c|start_of_role|\u003e\u0027 + msg.role + \u0027\u003c|end_of_role|\u003e\u0027 + c + \u0027\u003c|end_of_text|\u003e\\n\u0027 }}\n    {%- elif msg.role == \u0027assistant\u0027 %}\n{{- \u0027\u003c|start_of_role|\u003eassistant\u003c|end_of_role|\u003e\u0027 + c }}\n        {%- if msg.tool_calls %}\n            {%- for tc in msg.tool_calls %}\n                {%- set fn = tc.function if tc.function else tc %}\n                {%- if (loop.first and c) or not loop.first %}\n{{- \u0027\\n\u0027 }}\n                {%- endif %}\n                {%- set args_str = fn.arguments | tojson if fn.arguments is not string else fn.arguments %}\n{{- \u0027\u003ctool_call\u003e\\n{\"name\": \"\u0027 + fn.name + \u0027\", \"arguments\": \u0027 + args_str + \u0027}\\n\u003c/tool_call\u003e\u0027 }}\n            {%- endfor %}\n        {%- endif %}\n{{- \u0027\u003c|end_of_text|\u003e\\n\u0027 }}\n    {%- elif msg.role == \u0027tool\u0027 %}\n        {%- if loop.first or messages[loop.index0 - 1].role != \u0027tool\u0027 %}\n{{- \u0027\u003c|start_of_role|\u003euser\u003c|end_of_role|\u003e\u0027 }}\n        {%- endif %}\n{{- \u0027\\n\u003ctool_response\u003e\\n\u0027 + c + \u0027\\n\u003c/tool_response\u003e\u0027 }}\n        {%- if loop.last or messages[loop.index0 + 1].role != \u0027tool\u0027 %}\n{{- \u0027\u003c|end_of_text|\u003e\\n\u0027 }}\n        {%- endif %}\n    {%- endif %}\n{%- endfor %}\n{%- if add_generation_prompt %}\n{{- \u0027\u003c|start_of_role|\u003eassistant\u003c|end_of_role|\u003e\u0027 }}\n{%- endif %}\n}"
                                                                               },
